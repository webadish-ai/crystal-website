---
import Layout from '../../layouts/Layout.astro';
import CaseStudyPage from '../../components/company/CaseStudyPage';
import impactData from '../../data/impact.json';
import img0 from '../../data/images/build/_DSC4464 (5).jpg';
import img1 from '../../data/images/build/WhatsApp Image 2026-04-11 at 1.33.44 PM (1).jpeg';
import img2 from '../../data/images/build/WhatsApp Image 2026-04-11 at 1.33.45 PM.jpeg';

const heroImages = [img0, img1, img2];

export function getStaticPaths() {
  function toSlug(title: string): string {
    return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').substring(0, 80);
  }
  const section = impactData.page.sections.find((s: any) => s.type === 'case_studies') as any;
  return section.items.map((item: any, idx: number) => ({
    params: { slug: toSlug(item.title) },
    props: { item, idx },
  }));
}

interface CaseStudyItem {
  tag: string; title: string; client: string; location: string; product: string;
  challenge: string[]; solution: string[]; results: string[];
  outcomes: { kpi: string; value: string }[];
  testimonial?: { quote: string; author: string; company: string };
  pdf?: string | null;
}
const { item, idx } = Astro.props as { item: CaseStudyItem; idx: number };
const heroImage = (heroImages[idx] as any)?.src ?? heroImages[idx] as string;
---

<Layout
  title={`${item.title} | Case Study — Crystal Group`}
  description={item.challenge[0]?.substring(0, 155) ?? item.title}
>
  <CaseStudyPage client:load item={item} idx={idx} heroImage={heroImage} pdfUrl={item.pdf ?? undefined} />
</Layout>
